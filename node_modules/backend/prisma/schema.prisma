// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum'ы для статусов и ролей
enum Role {
  ADMIN
  LOGIST
  WAREHOUSE_WORKER
  MANAGER
  ACCOUNTANT
  CLIENT
}

enum MovementType {
  RECEIPT // Приемка
  ISSUE // Отпуск
  RESERVE // Резерв
  WRITE_OFF // Списание (брак)
  TRANSFER // Перемещение между складами
  CONSUMPTION // Расход материалов на производство
}

enum OrderStatus {
  NEW
  IN_PRODUCTION
  PACKED
  READY_FOR_SHIPMENT
  SHIPPED
  DELIVERED
  CANCELLED
}

enum BatchStatus {
  DRAFT
  QUARANTINE
  CERTIFIED
  ACTIVE
  SHIPPED
  SCRAPPED
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELAYED
  DELIVERED
  FAILED
}

enum DeliveryType {
  EXPRESS
  STANDARD
}

enum MaterialType {
  RAW_MATERIAL // Сырье
  PACKAGING // Упаковка
  LABEL // Этикетки
  AUXILIARY // Вспомогательные материалы
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
}

enum NotificationType {
  LOW_STOCK // Критические остатки
  EXPIRING_CERT // Срок действия сертификата
  OVERDUE_CONTRACT // Просрочка по договору
  SHIPMENT_DELAY // Задержка отгрузки
}

// Модель пользователей (роли, аудит, личный кабинет)
model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  role              Role
  passwordHash      String? // Для аутентификации (хранить хэш)
  preferredLanguage String   @default("RU") // RU, EN, CN для мультиязычности
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Аудит: действия пользователя
  actions Action[]

  // Заказы (менеджер/клиент)
  orders Order[]

  // Уведомления
  notifications Notification[]

  // Клиентский профиль (если роль CLIENT)
  customer          Customer?           @relation("UserCustomer")
  InventoryMovement InventoryMovement[]
  ChangeLog         ChangeLog[]

  @@map("users")
}

// Модель клиентов (связь с User для личного кабинета)
model Customer {
  id        String   @id @default(cuid())
  userId    String?  @unique
  name      String
  email     String?
  phone     String?
  region    String? // Для аналитики по регионам
  country   String? // Для экспорта
  address   String? // Адрес для доставки
  taxId     String? // Налоговый ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связь с User (один клиент - один пользователь, опционально)
  user User? @relation("UserCustomer", fields: [userId], references: [id])

  // Заказы
  orders    Order[]
  // Аналитика: контракты
  contracts Contract[]

  // Инвойсы
  invoices Invoice[]

  @@map("customers")
}

// Модель поставщиков (для закупок сырья)
model Supplier {
  id      String  @id @default(cuid())
  name    String
  email   String?
  phone   String?
  country String? // Для экспорта/импорта

  // Закупки
  purchases Purchase[]

  @@map("suppliers")
}

// Модель типов продукции (порошки, слитки, полосы)
model ProductType {
  id          String  @id @default(cuid())
  name        String // e.g., "Металлический порошок"
  category    String // e.g., "Порошки", "Слитки"
  unit        String // Единица измерения, e.g., "кг"
  description String? // Описание для отчетов

  // Партии этого типа
  batches Batch[]

  @@map("product_types")
}

// Модель материалов (сырье, упаковка и т.д.)
model Material {
  id        String       @id @default(cuid())
  name      String
  type      MaterialType
  unit      String // e.g., "кг", "шт"
  minStock  Float        @default(0) // Минимальный остаток для напоминаний
  createdAt DateTime     @default(now())

  // Закупки
  purchases Purchase[]

  // Расход по партиям
  consumptions Consumption[]

  @@map("materials")
}

// Модель партий (основная сущность для трассируемости)
model Batch {
  id             String      @id @default(cuid())
  batchNumber    String      @unique // Номер партии
  productTypeId  String
  productType    ProductType @relation(fields: [productTypeId], references: [id])
  quantity       Float // Количество
  unit           String // Из ProductType
  productionDate DateTime?
  expiryDate     DateTime? // Срок хранения
  parameters     Json? // Гранулометрия, химический состав { granulometry: {...}, composition: [...] }
  barcode        String? // Штрихкод/QR
  exportMarking  String? // Маркировка для экспорта
  status         String      @default("ACTIVE") // ACTIVE, QUARANTINE, CERTIFIED, SHIPPED, SCRAPPED
  packagingType  String? // Тип упаковки для трассируемости

  // Сертификаты и документы
  documents Document[]
  // Лабораторные анализы
  analyses  LabAnalysis[]

  // Складской учет: остатки по складам
  stockItems StockItem[]

  // Движения
  movements InventoryMovement[]

  // Заказы (привязка партии к заказу)
  orderItems   OrderItem[]
  // Расход материалов
  consumptions Consumption[]

  // История изменений (для визуализации)
  changeLogs ChangeLog[]

  minStock  Float?     @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  Purchase  Purchase[]

  @@index([batchNumber])
  @@index([status])
  @@index([parameters]) // Для фильтрации по параметрам (JSON search)
  @@index([expiryDate]) // Для напоминаний о сроках хранения
  @@map("batches")
}

// Модель складов (включая буферный/quarantine) - единая модель с self-relations
model Warehouse {
  id       String  @id @default(cuid())
  name     String // e.g., "Основной склад", "Буферный"
  type     String  @default("MAIN") // MAIN, BUFFER, QUARANTINE
  location String?
  capacity Float? // Емкость для аналитики

  // Остатки
  stockItems StockItem[]

  // Движения: self-relations для from/to
  movementsFrom InventoryMovement[] @relation("MovementsFrom")
  movementsTo   InventoryMovement[] @relation("MovementsTo")
  Shipment      Shipment[]

  @@map("warehouses")
}

// Модель остатков на складе
model StockItem {
  id          String    @id @default(cuid())
  batchId     String
  batch       Batch     @relation(fields: [batchId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Float
  reserved    Float     @default(0) // Резерв под заказы

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, warehouseId])
  @@index([quantity]) // Для поиска критических остатков
  @@map("stock_items")
}

// Модель движений товаров (приемка, отпуск и т.д.)
model InventoryMovement {
  id              String       @id @default(cuid())
  batchId         String
  batch           Batch        @relation(fields: [batchId], references: [id])
  fromWarehouseId String?
  fromWarehouse   Warehouse?   @relation("MovementsFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse?   @relation("MovementsTo", fields: [toWarehouseId], references: [id])
  type            MovementType
  quantity        Float
  date            DateTime     @default(now())
  reason          String? // e.g., "Списание брака"
  userId          String // Кто сделал движение
  user            User         @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([type])
  @@map("inventory_movements")
}

// Модель заказов
model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique
  customerId       String
  customer         Customer    @relation(fields: [customerId], references: [id])
  status           OrderStatus @default(NEW)
  totalAmount      Float?
  currency         String      @default("RUB")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  expectedDelivery DateTime? // Ожидаемая дата для контроля сроков

  // Позиции заказа (партии)
  orderItems OrderItem[]
  // Доставки
  shipments  Shipment[]

  // Управление: статус производства, упаковки
  productionNotes String?
  packingNotes    String?

  // Инвойсы
  invoices Invoice[]
  User     User?     @relation(fields: [userId], references: [id])
  userId   String?

  @@map("orders")
}

// Модель позиций заказа
model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id])
  batchId  String
  batch    Batch  @relation(fields: [batchId], references: [id])
  quantity Float
  price    Float? // Цена за единицу для аналитики

  @@unique([orderId, batchId])
  @@map("order_items")
}

// Модель доставок (логистика)
model Shipment {
  id              String         @id @default(cuid())
  orderId         String
  order           Order          @relation(fields: [orderId], references: [id])
  status          ShipmentStatus @default(PENDING)
  trackingNumber  String?
  deliveryType    DeliveryType   @default(STANDARD)
  cost            Float?
  estimatedDate   DateTime?
  actualDate      DateTime?
  carrier         String? // Транспортная компания
  fromWarehouseId String?
  fromWarehouse   Warehouse?     @relation(fields: [fromWarehouseId], references: [id])
  notes           String? // Заметки по задержкам

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([estimatedDate]) // Для контроля сроков
  @@map("shipments")
}

// Модель закупок (сырье, материалы)
model Purchase {
  id         String    @id @default(cuid())
  supplierId String
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  materialId String? // Для материалов
  material   Material? @relation(fields: [materialId], references: [id])
  batchId    String? // Если привязка к партии (для сырья в партию)
  batch      Batch?    @relation(fields: [batchId], references: [id])
  quantity   Float
  cost       Float
  date       DateTime  @default(now())
  type       String // e.g., "Сырье", "Упаковка"
  invoiceRef String? // Ссылка на инвойс поставщика

  @@map("purchases")
}

// Модель расхода материалов (на производство партии)
model Consumption {
  id         String   @id @default(cuid())
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id])
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Float
  date       DateTime @default(now())
  notes      String? // Нормы расхода и т.д.

  @@unique([batchId, materialId])
  @@map("consumptions")
}

// Модель документов (сертификаты, отчеты, этикетки)
model Document {
  id         String    @id @default(cuid())
  batchId    String
  batch      Batch     @relation(fields: [batchId], references: [id])
  type       String // e.g., "Сертификат качества", "Этикетка шаблон"
  filePath   String? // Путь к PDF/изображению
  expiryDate DateTime?
  issuedDate DateTime  @default(now())
  version    String? // Для копий/истории

  @@index([expiryDate]) // Для напоминаний о сроках
  @@map("documents")
}

// Модель лабораторных анализов
model LabAnalysis {
  id         String   @id @default(cuid())
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id])
  parameters Json // Результаты: { granulometry: {...}, composition: [...] }
  date       DateTime @default(now())
  approved   Boolean  @default(false)
  labNotes   String? // Заметки лаборатории

  @@map("lab_analyses")
}

// Модель контрактов (для аналитики)
model Contract {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  number     String    @unique // Номер контракта
  startDate  DateTime
  endDate    DateTime?
  value      Float // Общая сумма
  status     String    @default("ACTIVE") // ACTIVE, EXPIRED, TERMINATED

  @@index([endDate]) // Для просрочек
  @@map("contracts")
}

// Модель инвойсов (счетов)
model Invoice {
  id         String        @id @default(cuid())
  number     String        @unique
  orderId    String?
  order      Order?        @relation(fields: [orderId], references: [id])
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  amount     Float
  currency   String        @default("RUB")
  issueDate  DateTime      @default(now())
  dueDate    DateTime?
  status     InvoiceStatus @default(DRAFT)

  // Оплаты
  payments Payment[]

  @@index([dueDate]) // Для дебиторки и просрочек
  @@map("invoices")
}

// Модель оплат
model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  invoice   Invoice       @relation(fields: [invoiceId], references: [id])
  amount    Float
  date      DateTime      @default(now())
  status    PaymentStatus @default(PENDING)
  method    String? // e.g., "Bank transfer"

  @@map("payments")
}

// Модель логов изменений (аудит партий)
model ChangeLog {
  id        String   @id @default(cuid())
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String // e.g., "Updated parameters"
  oldValue  Json?
  newValue  Json?
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@map("change_logs")
}

// Модель действий пользователей (общий аудит)
model Action {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String // e.g., "Created batch"
  entityType String? // e.g., "Batch", "Order"
  entityId   String? // ID связанной сущности
  details    Json? // Дополнительные данные
  timestamp  DateTime @default(now())

  @@index([timestamp])
  @@index([entityType])
  @@map("actions")
}

// Модель уведомлений (напоминания)
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  message   String // Текст уведомления (локализованный в UI)
  relatedId String? // ID связанной сущности (batch, contract и т.д.)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([createdAt])
  @@index([type])
  @@map("notifications")
}
